{
  "expo": {
    "name": "Kāla काल AI",
    "slug": "kala",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "kala",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kala.app",
      "infoPlist": {
        "NSCalendarsUsageDescription": "Kāla a besoin d'accéder à votre calendrier pour y synchroniser vos événements.",
        "NSLocationWhenInUseUsageDescription": "Kāla utilise votre position pour trouver des lieux proches de vous."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.kala.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Kāla a besoin d'accéder à votre calendrier pour y synchroniser vos événements."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kāla utilise votre position pour trouver des lieux proches de vous.",
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
