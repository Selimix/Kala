{
  "expo": {
    "name": "Kāla काल AI",
    "slug": "kala",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "kala",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kala.app",
      "infoPlist": {
        "NSCalendarsUsageDescription": "Kāla a besoin d'accéder à votre calendrier pour y synchroniser vos événements.",
        "NSLocationWhenInUseUsageDescription": "Kāla utilise votre position pour trouver des lieux proches de vous.",
        "NSFaceIDUsageDescription": "Kāla utilise Face ID pour vous connecter rapidement.",
        "NSContactsUsageDescription": "Kāla accède à vos contacts pour vous aider à organiser des événements avec vos proches.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.kala.app",
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Kāla a besoin d'accéder à votre calendrier pour y synchroniser vos événements."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Kāla utilise Face ID pour vous connecter rapidement."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Kāla accède à vos contacts pour vous aider à organiser des événements avec vos proches."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kāla utilise votre position pour trouver des lieux proches de vous.",
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "ff9bb3a8-b62f-49a2-a23d-b838051b2b5f"
      }
    }
  }
}
